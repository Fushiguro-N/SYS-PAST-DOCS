@startuml
' Habilitar sombras y estilos visuales 3D
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome

skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Administrador" as Admin
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — EMPRESAS" {
    usecase "CU-08\nRegistrar empresa" as CU08
    usecase "Filtrar y validar RUC\nexistente en tiempo real" as Act1 <<system_action>>
    usecase "Desplegar formulario de\ndatos organizacionales" as Act2 <<system_action>>
}

Admin --> CU08 : Selecciona opción registrar
CU08 ..> Act1 : «include»
CU08 ..> Act2 : «include»
CU08 --> BD : Almacena información corporativa

note right of CU08
  📌 **Precondición:**
  • El usuario autenticado debe tener permisos de gestión.
  
  ✅ **Postcondición:**
  • La empresa queda registrada y habilitada en el sistema.
end note
@endum