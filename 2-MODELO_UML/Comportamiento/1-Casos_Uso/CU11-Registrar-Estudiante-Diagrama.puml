@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Administrador" as Admin
actor "Base de Datos de Pasantes" as BD <<Sistema>>
actor "Sistema Académico" as SysAcad <<Sistema>>

rectangle "SYS PASANTIAS — ESTUDIANTES" {
    usecase "CU-11\nRegistrar estudiante" as CU11
    usecase "Importar expediente y\ncréditos aprobados" as Act1 <<system_action>>
    usecase "Validar elegibilidad de\nmatrícula vigente" as Act2 <<system_action>>
}

Admin --> CU11 : Solicita registro de estudiante
CU11 ..> Act1 : «include»
CU11 ..> Act2 : «include»
CU11 --> SysAcad : Sincroniza datos del alumno
CU11 --> BD : Almacena registro de postulación

note right of CU11
  📌 **Precondición:**
  • El estudiante debe estar matriculado y cumplir con los requisitos académicos.
  
  ✅ **Postcondición:**
  • El estudiante queda registrado y habilitado para postular.
end note
@endum