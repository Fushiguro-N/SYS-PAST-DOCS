@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Administrador" as Admin
actor "Estudiante" as Est
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — ESTUDIANTES" {
    usecase "CU-12\nActualizar estudiante" as CU12
    usecase "Habilitar módulos de\nedición de CV y contacto" as Act1 <<system_action>>
}

Admin --> CU12 : Modifica datos asignados
Est --> CU12 : Actualiza información personal
CU12 ..> Act1 : «include»
CU12 --> BD : Guarda cambios en el perfil

note right of CU12
  📌 **Precondición:**
  • El estudiante debe estar registrado.
  
  ✅ **Postcondición:**
  • La información del estudiante es actualizada.
end note
@endum