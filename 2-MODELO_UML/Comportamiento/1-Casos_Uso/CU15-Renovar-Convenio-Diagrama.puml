@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Director" as Dir
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — CONVENIOS" {
    usecase "CU-15\nRenovar convenio" as CU15
    usecase "Calcular extensión de fechas\ny adjuntar adenda digital" as Act1 <<system_action>>
}

Dir --> CU15 : Gestiona adenda del convenio
CU15 ..> Act1 : «include»
CU15 --> BD : Actualiza periodo de validez legal

note right of CU15
  📌 **Precondición:**
  • El convenio debe estar registrado previamente.
  
  ✅ **Postcondición:**
  • La vigencia del convenio es extendida.
end note
@endum