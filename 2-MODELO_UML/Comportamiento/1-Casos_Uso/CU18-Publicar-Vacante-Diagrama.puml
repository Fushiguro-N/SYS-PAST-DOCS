@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Administrador" as Admin
actor "Director" as Dir
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — VACANTES" {
    usecase "CU-18\nPublicar vacante" as CU18
    usecase "Cambiar estatus a 'Publicada'\ny visibilizar en feed de alumnos" as Act1 <<system_action>>
}

Admin --> CU18 : Aprueba vacante solicitada
Dir --> CU18 : Autoriza publicación masiva
CU18 ..> Act1 : «include»
CU18 --> BD : Actualiza visibilidad global de la oferta

note right of CU18
  📌 **Precondición:**
  • La vacante debe haber sido registrada previamente.
  
  ✅ **Postcondición:**
  • La vacante es visible en el portal de los estudiantes.
end note
@endum