@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Estudiante" as Est
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — POSTULACIONES" {
    usecase "CU-19\nPostular a vacante" as CU19
    usecase "Vincular CV almacenado y\ngenerar ticket de postulación" as Act1 <<system_action>>
}

Est --> CU19 : Envía aplicación a oferta activa
CU19 ..> Act1 : «include»
CU19 --> BD : Registra emparejamiento estudiante-vacante

note right of CU19
  📌 **Precondición:**
  • El estudiante debe estar habilitado y la vacante en estado 'Publicada'.
  
  ✅ **Postcondición:**
  • La postulación es enviada exitosamente a la empresa.
end note
@endum