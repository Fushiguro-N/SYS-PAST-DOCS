@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Director" as Dir
actor "Administrador" as Admin
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — REPORTES" {
    usecase "CU-22\nGenerar reportes" as CU22
    usecase "Compilar métricas y estructurar\ndocumento analítico (PDF/Excel)" as Act1 <<system_action>>
}

Dir --> CU22 : Configura filtros estratégicos
Admin --> CU22 : Solicita métricas del ciclo
CU22 ..> Act1 : «include»
CU22 --> BD : Extrae analíticas agregadas

note right of CU22
  📌 **Precondición:**
  • El usuario debe tener acceso al módulo de analítica.
  
  ✅ **Postcondición:**
  • Se obtiene el documento del reporte solicitado.
end note
@endum