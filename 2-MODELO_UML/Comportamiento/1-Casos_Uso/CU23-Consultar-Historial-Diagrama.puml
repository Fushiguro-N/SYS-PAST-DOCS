@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Director" as Dir
actor "Administrador" as Admin
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — REPORTES" {
    usecase "CU-23\nConsultar historial" as CU23
    usecase "Estructurar línea de tiempo de\nprocesos académicos previos" as Act1 <<system_action>>
}

Dir --> CU23 : Consulta auditorías pasadas
Admin --> CU23 : Audita flujos históricos concluídos
CU23 ..> Act1 : «include»
CU23 --> BD : Consulta tablas de histórico archivado

note right of CU23
  📌 **Precondición:**
  • Acceso al sistema concedido.
  
  ✅ **Postcondición:**
  • Se muestra la información de auditoría o histórica requerida.
end note
@endum