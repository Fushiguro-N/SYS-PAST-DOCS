@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Director" as Dir
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — SEGUIMIENTO" {
    usecase "CU-24\nAsignar supervisor" as CU24
    usecase "Desplegar docentes habilitados\ny enviar alertas de tutoría" as Act1 <<system_action>>
}

Dir --> CU24 : Vincula docente con alumno activo
CU24 ..> Act1 : «include»
CU24 --> BD : Asocia registros de supervisión académica

note right of CU24
  📌 **Precondición:**
  • El estudiante debe tener una pasantía aprobada e iniciada.
  
  ✅ **Postcondición:**
  • El estudiante cuenta con un supervisor asignado para su monitoreo.
end note
@endum