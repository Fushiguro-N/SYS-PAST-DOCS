@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Supervisor" as Sup
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — SEGUIMIENTO" {
    usecase "CU-25\nRegistrar seguimiento" as CU25
    usecase "Habilitar formulario de bitácoras\ny control de horas acumuladas" as Act1 <<system_action>>
}

Sup --> CU25 : Registra incidencias o visitas de campo
CU25 ..> Act1 : «include»
CU25 --> BD : Almacena bitácora en la ficha del alumno

note right of CU25
  📌 **Precondición:**
  • El supervisor debe tener asignado al alumno.
  
  ✅ **Postcondición:**
  • Se añade una nueva bitácora de seguimiento al expediente de la pasantía.
end note
@endum