@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Empresa" as Emp
actor "Supervisor" as Sup
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — SEGUIMIENTO" {
    usecase "CU-26\nEvaluar desempeño" as CU26
    usecase "Desplegar matriz de rúbricas\ny promediar calificación ponderada" as Act1 <<system_action>>
}

Emp --> CU26 : Evalúa competencias corporativas
Sup --> CU26 : Asigna notas de informe final
CU26 ..> Act1 : «include»
CU26 --> BD : Consolida calificaciones de la pasantía

note right of CU26
  📌 **Precondición:**
  • La pasantía debe estar en su etapa final o concluida.
  
  ✅ **Postcondición:**
  • El estudiante queda evaluado formalmente por sus actividades.
end note
@endum