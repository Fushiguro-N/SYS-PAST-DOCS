@startuml
skinparam shadowing true
skinparam roundcorner 15
skinparam actorStyle awesome
skinparam backgroundcolor #FAFAFA

skinparam rectangle {
    BackgroundColor #F2F4F4-#E5E8E8
    BorderColor #2C3E50
    BorderThickness 2
    FontColor #2C3E50
    FontSize 14
    FontStyle bold
}

skinparam usecase {
    BackgroundColor #2980B9-#5DADE2
    BorderColor #1B4F72
    BorderThickness 1.5
    FontColor #FFFFFF
    FontSize 12
    FontStyle bold
    
    BackgroundColor<<system_action>> #117864-#1ABC9C
    BorderColor<<system_action>> #0E6251
    FontColor<<system_action>> #FFFFFF
}

skinparam actor {
    BackgroundColor #D35400-#E67E22
    BorderColor #A04000
    BorderThickness 1.5
    FontColor #2C3E50
    FontSize 12
    FontStyle bold
}

actor "Director" as Dir
actor "Base de Datos de Pasantes" as BD <<Sistema>>

rectangle "SYS PASANTIAS — CIERRE" {
    usecase "CU-28\nCerrar proceso" as CU28
    usecase "Verificar checklist completo\ny archivar expediente físico/digital" as Act1 <<system_action>>
}

Dir --> CU28 : Concluye oficialmente el ciclo
CU28 ..> Act1 : «include»
CU28 --> BD : Cambia estatus final a 'Archivado / Concluido'

note right of CU28
  📌 **Precondición:**
  • La constancia debió ser emitida y todos los documentos archivados.
  
  ✅ **Postcondición:**
  • El expediente pasa al archivo histórico del sistema, liberando al alumno del proceso activo.
end note
@endum